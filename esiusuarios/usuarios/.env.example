# Copia este archivo a .env y adapta los valores a tu SQL Server local.
# No subas .env al repositorio.

# Si usas SQL Server instalado en Windows normalmente sera 1433.
# Si usas el docker-compose de Backend, el puerto publicado es 14333.
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=esiusuarios
SQLSERVER_USER=usuarios_app
SQLSERVER_PASSWORD=UsuariosApp!2026

# Variables opcionales para correo y seguridad de aplicacion.
APP_FRONTEND_URL=http://localhost:4200
RISK_DATA_ENCRYPTION_KEY=
INTERNAL_API_SECRET=
